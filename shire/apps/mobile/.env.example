# Expo public env vars for the mobile app.
# Copy this file to .env in the same directory and fill in real values.

EXPO_PUBLIC_API_URL=https://web-production-5c5b4.up.railway.app/api/v1
EXPO_PUBLIC_WS_URL=wss://web-production-5c5b4.up.railway.app

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_APP_ENV=production

# Apple / EAS build vars used by app.config.ts. These are build-time only and
# should not use the EXPO_PUBLIC_ prefix.
EXPO_IOS_BUNDLE_IDENTIFIER=com.shire.mobile
EXPO_IOS_BUILD_NUMBER=1
EXPO_APPLE_TEAM_ID=
EXPO_EAS_PROJECT_ID=
