{
  "expo": {
    "name": "Shire",
    "slug": "shire",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "scheme": "shire",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shire.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.shire.mobile",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "output": "static",
      "bundler": "metro"
    },
    "plugins": [
      ["expo-router", { "root": "./src/app" }],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1a1a2e",
          "dark": {
            "backgroundColor": "#1a1a2e"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "baseUrl": ""
    }
  }
}
