{
  "name": "shire",
  "private": true,
  "scripts": {
    "start": "pnpm dev:host",
    "start:tunnel": "pnpm dev:host:tunnel",
    "dev": "turbo dev",
    "dev:host": "turbo dev --filter=@shire/mobile",
    "dev:host:tunnel": "pnpm --filter @shire/mobile dev:tunnel",
    "dev:ios:sim": "pnpm --filter @shire/mobile ios:sim",
    "dev:ios:ipad-mini": "pnpm --filter @shire/mobile ios:ipad-mini",
    "dev:ios:ipad-pro": "pnpm --filter @shire/mobile ios:ipad-pro",
    "ios:sim": "pnpm --filter @shire/mobile ios:sim",
    "ios:ipad-mini": "pnpm --filter @shire/mobile ios:ipad-mini",
    "ios:ipad-pro": "pnpm --filter @shire/mobile ios:ipad-pro",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "packageManager": "pnpm@9.15.4"
}
